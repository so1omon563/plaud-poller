PLAUD_AUTHORIZATION=
# Or use PLAUD_TOKEN if the token should be sent as Bearer <token>.
PLAUD_TOKEN=

# Known region keys: aws:us-west-2, aws:eu-central-1, aws:ap-southeast-1
PLAUD_REGION=aws:us-west-2

# Optional paths. Leave blank to use portable defaults:
#   macOS:   ~/Library/Application Support/plaud-poller
#   Linux:   ${XDG_DATA_HOME:-~/.local/share}/plaud-poller
#   Windows: %LOCALAPPDATA%\plaud-poller or %APPDATA%\plaud-poller
PLAUD_DATA_DIR=
PLAUD_RECORDINGS_DIR=
PLAUD_STATE_DB=

# Set this to your Obsidian vault subfolder if you want notes written directly
# into Obsidian, for example:
#   PLAUD_OBSIDIAN_DIR=~/Documents/Obsidian/Plaud
# If blank, notes are written under $PLAUD_DATA_DIR/obsidian-notes.
PLAUD_OBSIDIAN_DIR=

PLAUD_PAGE_SIZE=50
PLAUD_DOWNLOAD_AUDIO=false
# Include full transcript text in generated Markdown notes. Transcript artifacts
# are still saved locally even when this is false.
PLAUD_NOTE_INCLUDE_TRANSCRIPT=true
# Include PLAUD's outline blob as an additional Markdown section in notes.
# Outline artifacts are still saved locally even when this is false.
PLAUD_NOTE_INCLUDE_OUTLINE=false
# Preserve local Markdown task checkbox state when regenerated PLAUD summaries
# contain the same task text. Useful with Obsidian Tasks dashboards. Set false
# if PLAUD should overwrite local task completion state.
PLAUD_PRESERVE_TASK_STATE=true
# Default is active recordings only. Set true to also sync PLAUD trash.
PLAUD_INCLUDE_TRASH=false
# What to do with previously synced notes that later disappear from active PLAUD
# results because they were trashed or removed: keep, archive, or delete.
PLAUD_TRASH_POLICY=archive
# Defaults to $PLAUD_OBSIDIAN_DIR/_Archive/plaud-trash.
PLAUD_TRASH_ARCHIVE_DIR=

# Poll output: quiet, changes, summary, or verbose. "changes" is quiet when
# nothing changed, but prints changed records and a summary when work happened.
PLAUD_REPORT_MODE=changes
# If true, copy an existing Obsidian note to a version archive before the poller
# overwrites or renames it.
PLAUD_NOTE_BACKUP_ON_CHANGE=false
# Defaults to $PLAUD_OBSIDIAN_DIR/_Archive/plaud-note-versions.
PLAUD_NOTE_BACKUP_DIR=

# Optional: scan local Chromium-family browser storage for a newer valid
# web.plaud.ai session token before each poll. Useful on personal machines
# where you stay logged into PLAUD in Chrome/Brave/Edge/Arc/Vivaldi.
# If PLAUD rejects the stored refresh token and requires a full re-exchange,
# run: python3 -m plaud_poller.auth browser-login --env .env --method google
# The method hint can be google, apple, email, or generic; the login happens
# in the browser and only resulting PLAUD token metadata is used.
PLAUD_AUTO_REFRESH_TOKEN=false
PLAUD_REFRESH_MIN_TTL_SECONDS=3600
# Optional: after a rejected token and failed storage-only refresh, open PLAUD
# in Chrome once, wait for a fresh PLAUD workspace session, and retry the poll.
# This never reads provider credentials or automates MFA/consent. Failed browser
# attempts are throttled by a local marker under PLAUD_DATA_DIR.
PLAUD_AUTO_BROWSER_LOGIN=false
PLAUD_AUTO_BROWSER_LOGIN_METHOD=generic
PLAUD_AUTO_BROWSER_LOGIN_TIMEOUT_SECONDS=90
PLAUD_AUTO_BROWSER_LOGIN_INTERVAL_SECONDS=5
PLAUD_AUTO_BROWSER_LOGIN_COOLDOWN_SECONDS=21600
